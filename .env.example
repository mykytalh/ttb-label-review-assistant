# Copy to .env.local and fill in. NEVER commit a real key.
# The app reads only ANTHROPIC_API_KEY (server-side in /api/review). It is never
# sent to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the extraction model. Defaults to claude-haiku-4-5 — fast
# (reliably under the 5s budget) and low-cost for large batches. Set this to
# claude-opus-4-8 for stronger robustness on the hardest glare/skew photos.
# LABEL_MODEL=claude-opus-4-8
